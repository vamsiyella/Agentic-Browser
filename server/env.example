# ── Provider selection ────────────────────────────────────────────────
# "nvidia" (free), "ollama" (local, free), or "anthropic" (paid — best
# grounding, and uses native tool-calling instead of prompted JSON, so it
# doesn't fall over on JSON-parse errors the way small open models do)
PROVIDER=nvidia

# ── NVIDIA NIM (free tier) ────────────────────────────────────────────
# Get your free key at: https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.2-90b-vision-instruct

# ── Ollama (fully local) ──────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llava-phi3

# ── Anthropic (paid) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Cheaper/faster alternative: claude-haiku-4-5-20251001

# ── Budget guardrails (Anthropic only — NVIDIA/Ollama are free, so these
#    are skipped entirely for them) ─────────────────────────────────────
MAX_COST_PER_TASK_USD=1.00
DAILY_BUDGET_USD=10.00
# Only change these if Anthropic's published pricing changes:
ANTHROPIC_INPUT_COST_PER_MTOK=3.00
ANTHROPIC_OUTPUT_COST_PER_MTOK=15.00
